{
    "input_model": {
        "type": "ONNXModel",
        "model_path": "sam21_vision_encoder.onnx"
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [
                {
                    "device": "gpu",
                    "execution_providers": [
                        "CUDAExecutionProvider"
                    ]
                }
            ]
        }
    },
    "data_configs": [
        {
            "name": "latency_data_config",
            "user_script": "user_script.py",
            "load_dataset_config": {
                "type": "local_dataset"
            },
            "dataloader_config": {
                "type": "ve_data_loader",
                "batch_size": 1
            }
        },
        {
            "name": "quantize_data_config",
            "user_script": "user_script.py",
            "load_dataset_config": {
                "type": "local_dataset"
            },
            "dataloader_config": {
                "type": "ve_quantize_data_loader",
                "data_num": 100
            }
        }
    ],
    "evaluators": {
        "common_evaluator": {
            "metrics": [
                {
                    "name": "latency",
                    "type": "latency",
                    "data_config": "latency_data_config",
                    "sub_types": [
                        {
                            "name": "avg",
                            "priority": 1
                        }
                    ]
                }
            ]
        }
    },
    "passes": {
        "quantization": {
            "type": "OnnxStaticQuantization",
            "data_config": "quantize_data_config",
            "activation_type": "uint8",
            "precision": "uint8",
            "calibrate_method": "MinMax",
            "quant_preprocess": true,
            "calibration_providers": [
                "CUDAExecutionProvider"
            ]
        }
    },
    "log_severity_level": 1,
    "ort_log_severity_level": 1,
    "ort_py_log_severity_level": 1,
    "evaluate_input_model": false,
    "host": "local_system",
    "target": "target_system",
    "cache_dir": "cache_encoder_qdq",
    "output_dir": "model/encoder_qdq"
}