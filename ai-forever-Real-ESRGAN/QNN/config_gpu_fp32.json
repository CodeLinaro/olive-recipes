{
    "input_model": {
        "type": "PyTorchModel",
        "model_path": "ai-forever/Real-ESRGAN",
        "model_loader": "model_loader",
        "model_script": "esrgan_load.py",
        "io_config": {
            "input_names": ["pixel_values"],
            "input_shapes": [[1, 3, 250, 250]],
            "output_names": ["upscaled_pixel_values"]
        }
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [ { "device": "gpu", "execution_providers": [ "QNNExecutionProvider" ] } ]
        }
    },
    "passes": {
        "conversion": { "device": "cpu", "type": "OnnxConversion", "target_opset": 20 },
        "add_metadata": { "type": "AddOliveMetadata", "graph_name": "main_graph" }
    },
    "host": "local_system",
    "target": "local_system",
    "cache_dir": "cache",
    "output_dir": "output"
}

