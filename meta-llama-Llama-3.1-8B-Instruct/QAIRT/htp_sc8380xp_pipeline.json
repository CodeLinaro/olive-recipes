{
    "input_model": {
        "type": "HFModel",
        "model_path": "meta-llama/Llama-3.1-8B-Instruct"
    },
    "passes": {
        "qp": {
            "type": "QairtPipelinePass",
            "recipe": "llama31_8b_instruct_sc8380xp.yaml",
            "cache_dir": "cache/qairt"
        },
        "qe": {
            "type": "QairtEncapsulation",
            "log_level": "ERROR",
            "run_checker": "true",
            "engine_config_overrides": {
                "n_threads": 0,
                "htp": {
                    "cpu_mask": "0xe0",
                    "allow_async_init": false,
                    "poll": false,
                    "mmap_budget": 0
                }
            },
            "backend_extensions_overrides": {
                "context": [{"reused_io_limit_mb": 100}],
                "graphs": null,
                "devices": [{"pd_session": "unsigned"}],
                "groupContext": {"share_resources": false}
            }
        }
    },
    "log_severity_level": 1,
    "output_dir": "models/llama3_1-8b-instruct-qairt-htp-sc8380xp",
    "cache_dir": "cache",
    "no_artifacts": true
}
