{
    "input_model": {
        "type": "HFModel",
        "model_path": "meta-llama/Llama-3.1-8B-Instruct"
    },
    "passes": {
        "qp": {
            "type": "QairtPreparation",
            "script_path": "llama3_1_instruct_script.py",
            "script_config": {
                "PLATFORM_GEN": 2
            }
        },
        "qgab": {
            "type": "QairtGenAIBuilder",
            "log_level": "INFO",
            "backend": "HTP",
            "soc_details": "chipset:SC8380XP",
            "vtcm_size_in_mb": 8,
            "hvx_threads": 8,
            "extended_udma": false,
	    "sequence_lengths": [32, 128],
            "native_kv": true,
            "multi_graph": true
        },
        "qe": {
            "type": "QairtEncapsulation",
            "log_level": "ERROR",
            "run_checker": "true",
            "htp_execution_overrides": {
                "cpu_mask": "0xe0",
                "n_threads": 0,
                "allow_async_init": false,
                "poll": false,
                "mmap_budget": 0
            },
            "backend_extensions_overrides": {
                "reused_io_limit_mb": 100,
                "rpc_control_latency": 100
            }
        }
    },
    "log_severity_level": 1,
    "output_dir": "models/llama3_1-8b-instruct-qairt-htp-sc8380xp",
    "cache_dir": "cache",
    "no_artifacts": true
}
